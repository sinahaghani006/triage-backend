// Prisma schema -- Sprint 1 minimal scope
// Tables: Users (with authentication fields merged in), Sessions
// Decision (within backend-core's own authority): UserAuthentication is merged
// into Users for Sprint 1 to avoid a premature 1:1 join; documented in README
// under "Design Decisions". Can be split into its own table later without
// breaking the API contract if the auth data grows (e.g. multiple auth
// providers, refresh tokens table, etc.)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SessionState {
  S1_initial_state
  S2_collecting_information
  S3_assign_urgency
  S4_ai_triage_processing
  S5_pending_doctor_review
  S6_marked_emergency
  S7_marked_home_treatment
  S8_marked_normal
  S9_completed_triage
  S10_cancelled_by_user
}

// RBAC (2026-07-21): patient/doctor/admin. Renamed from the old
// patient/staff pair via ALTER TYPE ... RENAME VALUE in the migration,
// so existing staff accounts become doctor accounts automatically.
enum UserRole {
  patient
  doctor
  admin
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(patient)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sessions          Session[]
  patientDetails    PatientDetails?
  historySummaries  PatientHistorySummary[]
  medicalHistory    MedicalHistory?
  periodicVitals    PeriodicVitals[]
  wallet            Wallet?

  @@map("users")
}

// Static demographic data about the patient. birthDate is the source of
// truth for age -- age is computed server-side at submit-symptoms time.
// 2026-07-21: no longer captured during /auth/register itself -- the
// Frontend now calls PATCH /users/me/patient-details as registration
// step 2, immediately after step 1 (email/password) succeeds.
model PatientDetails {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  birthDate DateTime @map("birth_date")
  weightKg  Float?   @map("weight_kg")
  heightCm  Float?   @map("height_cm")
  gender    String?  @map("gender")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_details")
}

model Session {
  id                  String        @id @default(uuid())
  userId              String        @map("user_id")
  currentState        SessionState  @default(S2_collecting_information) @map("current_state")
  presentingProblemId String?       @map("presenting_problem_id")
  closedAt            DateTime?     @map("closed_at")
  cancelledAt         DateTime?     @map("cancelled_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  feedback       PatientFeedback?
  historySummary PatientHistorySummary?
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  triageResult   TriageResult?

  @@map("sessions")
  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
  @@index([userId])
  @@index([entityType, entityId])
}

model ErrorLog {
  id         String   @id @default(uuid())
  code       String?
  message    String
  stack      String?
  path       String?
  method     String?
  statusCode Int?     @map("status_code")
  userId     String?  @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("error_logs")
}

model TriageResult {
  id               String   @id @default(uuid())
  sessionId        String   @unique @map("session_id")
  urgencyLevel     String   @map("urgency_level")
  triageResultJson Json     @map("triage_result_json")
  createdAt        DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("triage_results")
}

model PatientFeedback {
  id        String   @id @default(uuid())
  sessionId String   @unique @map("session_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("patient_feedback")
}

model PatientHistorySummary {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  sessionId           String   @unique @map("session_id")
  presentingProblemId String?  @map("presenting_problem_id")
  urgencyLevel        String   @map("urgency_level")
  reasoningSummary    String?  @map("reasoning_summary")
  createdAt           DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("patient_history_summaries")
  @@index([userId])
}

model MedicalHistory {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  chronicConditions  String[] @map("chronic_conditions")
  allergies          String[] @map("allergies")
  currentMedications String[] @map("current_medications")
  surgicalHistory    String[] @map("surgical_history")
  familyHistory      String[] @map("family_history")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_history")
}

model PeriodicVitals {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String
  value      Json
  recordedAt DateTime @default(now()) @map("recorded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("periodic_vitals")
  @@index([userId])
  @@index([userId, type])
}

// Wallet (2026-07-21): balance in Toman. Default 100000, each completed
// triage deducts 10000 (both figures are placeholders pending the revenue
// planning session). Daily limit of 5 triages is enforced separately by
// counting today's PatientHistorySummary rows -- no counter field needed.
model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  balance   Int      @default(100000)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}