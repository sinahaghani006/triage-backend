# --- Database ---
# Local dev: plain PostgreSQL connection string.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/triage_db?schema=public"
# Neon (production, on Vercel): DATABASE_URL must be the POOLED connection
# string (has "-pooler" in the host, or add ?pgbouncer=true) — serverless
# functions can't hold long-lived direct connections. DIRECT_URL is Neon's
# non-pooled string, used only by `prisma migrate` (pooled connections don't
# support migrations). Both are given on the Neon project's dashboard.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.neon.tech/triage_db?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.neon.tech/triage_db?sslmode=require"

# --- Server ---
PORT=3000
# development locally; set to "production" in Vercel's env vars — this also
# flips cookie Secure/SameSite behavior (see setAuthCookie in authController.js).
NODE_ENV=development

# --- CORS / Cookies ---
# Must match the exact origin (scheme+host+port) the Frontend app runs on,
# so the browser will accept the httpOnly auth cookie set on /auth/register.
# Local dev: Frontend team confirmed they're pinned to port 3001.
# Production (Vercel): update to the real Frontend *.vercel.app URL once
# assigned — e.g. "https://triage-frontend-xxxx.vercel.app" (no trailing slash).
FRONTEND_ORIGIN="http://localhost:3001"

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"
